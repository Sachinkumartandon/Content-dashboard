

# ─── NewsAPI ─────────────────────────────────────────────────────────────────
# Get your free key at: https://newsapi.org/register
# Used in: src/app/api/news/route.ts (server-side only)
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_BASE_URL=https://newsapi.org/v2


# ─── TMDB (The Movie Database) ───────────────────────────────────────────────
# Get your free key at: https://www.themoviedb.org/settings/api
# Used in: src/app/api/recommendations/route.ts (server-side only)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p


# ─── NextAuth (Authentication) ───────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
# Used in: src/app/api/auth/[...nextauth]/route.ts
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — for Google login)
# Get credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth (optional — for GitHub login)
# Get credentials at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here


# ─── App Config (Public — safe to expose to browser) ─────────────────────────
# NEXT_PUBLIC_ prefix makes these available on the client side
NEXT_PUBLIC_APP_NAME=ContentDash
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0


# ─── Real-time / WebSocket (Bonus Feature) ───────────────────────────────────
# Used in: src/lib/socket.ts (for real-time feed updates)
# Leave empty if not implementing the real-time bonus feature
NEXT_PUBLIC_SOCKET_URL=


# ─── How to use in code ───────────────────────────────────────────────────────
#
#   Server-side only (API routes, Server Components):
#   const apiKey = process.env.NEWS_API_KEY
#
#   Client-side (anywhere):
#   const appName = process.env.NEXT_PUBLIC_APP_NAME
#
#   ✅ NEWS_API_KEY            → server only  → safe
#   ✅ TMDB_API_KEY            → server only  → safe
#   ✅ TMDB_READ_ACCESS_TOKEN  → server only  → safe
#   ✅ NEXTAUTH_SECRET         → server only  → safe
#   ✅ NEXT_PUBLIC_APP_*       → client safe  → no sensitive data here
# ============================================================
